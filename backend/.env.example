# ---- LLM ----
OPENAI_API_KEY=sk-...

# ---- Telegram ----
# 1. In Telegram, message @BotFather, run /newbot, save the token below.
# 2. Send any message to your new bot from your Telegram account.
# 3. Run: python scripts/test_telegram.py  -- it will discover and print your chat_id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Google ----
# Path to the OAuth client credentials JSON downloaded from Google Cloud.
# (Desktop app type. Enable: YouTube Data v3, Gmail API, Calendar API.)
GOOGLE_CREDENTIALS_PATH=./data/credentials.json
# Where the long-lived refresh token is cached after the first browser login.
GOOGLE_TOKEN_PATH=./data/token.json

# ---- Gmail filtering ----
# Search query for the email agent. Default excludes the Promotions tab so
# advertising / marketing mail never reaches the LLM. Useful tweaks:
#   stricter:  newer_than:2d in:inbox -category:{promotions social updates}
#   looser:    newer_than:2d in:inbox
# Full Gmail search-operator reference: https://support.google.com/mail/answer/7190
GMAIL_QUERY=newer_than:2d in:inbox -category:promotions

# Comma-separated case-insensitive substrings matched against the sender's
# email address. Any match is dropped before the LLM call. Catches promo
# senders that slip past Gmail's Promotions tab.
# Example:  GMAIL_IGNORE_FROM=no-reply@,newsletter@,marketing@,@mailchimp.com,@substack.com
GMAIL_IGNORE_FROM=

# ---- App ----
APP_TIMEZONE=America/New_York
APP_DB_URL=sqlite:///./data/agentic.db
APP_LOG_LEVEL=INFO
# Cron for the daily brief. Defaults to 08:00 in APP_TIMEZONE.
APP_BRIEF_HOUR=8
APP_BRIEF_MINUTE=0
